{
  "name": "westchester-housing",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "description": "Westchester Housing — powered by Ordinizer",
  "scripts": {
    "dev": "cross-env NODE_ENV=development npx tsx server/index.ts",
    "build-local": "npx vite build && esbuild server/index.ts --platform=node --bundle --packages=bundle --external:vite --format=cjs --outdir=dist --out-extension:.js=.cjs",
    "build": "npx vite build && esbuild server/index.ts --platform=node --bundle --packages=bundle --external:vite --format=cjs --outdir=dist --out-extension:.js=.cjs",
    "start": "cross-env NODE_ENV=production node dist/index.cjs",
    "check": "tsc",
    "load-local": "npm install ../ordinizer/app/client ../ordinizer/app/server ../ordinizer/app/analyzer",
    "load-latest": "npm install @civillyengaged/ordinizer-client@latest @civillyengaged/ordinizer-server@latest"
  },
  "dependencies": {
    "@civillyengaged/ordinizer-analyzer": "file:../ordinizer/app/analyzer",
    "@civillyengaged/ordinizer-client": "^1.0.8",
    "@civillyengaged/ordinizer-server": "^1.0.6",
    "@pinecone-database/pinecone": "^6.1.2",
